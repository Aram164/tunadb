# name: test/sql/match_recognize/test_nfa.test
# description: Minimal NFA integration tests (PHY1, all-true masks, NULL measures)
# group: [match_recognize]

statement ok
CREATE TABLE t(id INTEGER, ts INTEGER);

statement ok
INSERT INTO t VALUES (1, 1), (2, 2), (3, 3), (4, 4);


# --- Pattern "A B" (concat), AFTER MATCH SKIP TO NEXT ROW ---
# 4 rows: start at 0->match(0,1), start at 1->match(1,2), start at 2->match(2,3), start at 3->no match -> 3 matches
query I
SELECT count(*) FROM t MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP TO NEXT ROW
    PATTERN ('A B')
    DEFINE A AS A.id >= 0, B AS B.id >= 0
)
----
3

# --- Pattern "A B+", SKIP PAST LAST ROW ---
# Greedy: one A (row 0) then B+ consumes rows 1-3 -> 1 match
query I
SELECT count(*) FROM t MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A B+')
    DEFINE A AS A.id >= 0, B AS B.id >= 0
)
----
1

# --- PARTITION BY: two groups matched independently ---
# group p=1: 3 rows, "A+" -> 1 match
# group p=2: 2 rows, "A+" -> 1 match
# total: 2 matches
statement ok
CREATE TABLE t2(id INTEGER, ts INTEGER, p INTEGER);

statement ok
INSERT INTO t2 VALUES (1, 1, 1), (2, 2, 1), (3, 3, 1), (4, 1, 2), (5, 2, 2);

query I
SELECT count(*) FROM t2 MATCH_RECOGNIZE (
    PARTITION BY p
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A+')
    DEFINE A AS A.id >= 0
)
----
2

# --- MEASURES output now returns bound values instead of the old PHY1 NULL placeholder ---
query I
SELECT m IS NULL FROM t MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A B')
    DEFINE A AS A.id >= 0, B AS B.id >= 0
)
----
0
0

# --- MEASURES input columns must survive child column remapping/pruning ---
statement ok
CREATE TABLE t3(id INTEGER, payload INTEGER, ts INTEGER);

statement ok
INSERT INTO t3 VALUES (1, 10, 1), (2, 20, 2), (3, 30, 3);

query I
SELECT m FROM t3 MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES A.payload AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A')
    DEFINE A AS A.id >= 0
)
----
10
20
30

# --- FIRST vs LAST: must return different rows ---
# Pattern "A B+": A binds row 0 (id=1), B binds rows 1-3 (id=2,3,4)
# FIRST(A.id) = 1, LAST(B.id) = 4
query II
SELECT first_val, last_val FROM t MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES FIRST(A.id) AS first_val, LAST(B.id) AS last_val
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A B+')
    DEFINE A AS A.id >= 0, B AS B.id >= 0
)
----
1	4

# --- Tie detection: two rows with same ORDER BY value -> error ---
statement error
SELECT count(*) FROM (VALUES (1, 5), (2, 5)) t(id, ts) MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A')
    DEFINE A AS A.id >= 0
)
----
no ties
