# name: test/sql/match_recognize/test_nfa.test
# description: Minimal NFA integration tests (PHY1, all-true masks, NULL measures)
# group: [match_recognize]

statement ok
CREATE TABLE t(id INTEGER, ts INTEGER);

statement ok
INSERT INTO t VALUES (1, 1), (2, 2), (3, 3), (4, 4);


# --- Pattern "A B" (concat), AFTER MATCH SKIP TO NEXT ROW ---
# 4 rows: start at 0->match(0,1), start at 1->match(1,2), start at 2->match(2,3), start at 3->no match -> 3 matches
query I
SELECT count(*) FROM t MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP TO NEXT ROW
    PATTERN ('A B')
    DEFINE A AS A.id >= 0, B AS B.id >= 0
)
----
3

# --- Pattern "A B+", SKIP PAST LAST ROW ---
# Greedy: one A (row 0) then B+ consumes rows 1-3 -> 1 match
query I
SELECT count(*) FROM t MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A B+')
    DEFINE A AS A.id >= 0, B AS B.id >= 0
)
----
1

# --- PARTITION BY: two groups matched independently ---
# group p=1: 3 rows, "A+" -> 1 match
# group p=2: 2 rows, "A+" -> 1 match
# total: 2 matches
statement ok
CREATE TABLE t2(id INTEGER, ts INTEGER, p INTEGER);

statement ok
INSERT INTO t2 VALUES (1, 1, 1), (2, 2, 1), (3, 3, 1), (4, 1, 2), (5, 2, 2);

query I
SELECT count(*) FROM t2 MATCH_RECOGNIZE (
    PARTITION BY p
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A+')
    DEFINE A AS A.id >= 0
)
----
2

# --- MEASURES output is currently NULL (PHY1 placeholder) ---
query I
SELECT m IS NULL FROM t MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A B')
    DEFINE A AS A.id >= 0, B AS B.id >= 0
)
----
true
true

# --- Tie detection: two rows with same ORDER BY value -> error ---
statement error
SELECT count(*) FROM (VALUES (1, 5), (2, 5)) t(id, ts) MATCH_RECOGNIZE (
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A')
    DEFINE A AS A.id >= 0
)
----
no ties
