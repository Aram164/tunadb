# name: test/sql/match_recognize/prev.test
# description: MATCH_RECOGNIZE PREV() behavior
# group: [match_recognize]

statement ok
CREATE TABLE t_prev_only(id INTEGER, price INTEGER, ts INTEGER, p INTEGER);

statement ok
INSERT INTO t_prev_only VALUES
    (1, 10, 1, 1), (2, 9, 2, 1), (3, 8, 3, 1),
    (4, 7, 1, 2), (5, 6, 2, 2), (6, 5, 3, 2);

query I
SELECT count(*) FROM t_prev_only MATCH_RECOGNIZE (
    PARTITION BY p
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP TO NEXT ROW
    PATTERN ('A')
    DEFINE A AS PREV(A.price) IS NULL
)
----
2

query I
SELECT count(*) FROM t_prev_only MATCH_RECOGNIZE (
    PARTITION BY p
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP PAST LAST ROW
    PATTERN ('A B+')
    DEFINE A AS A.price >= 0,
           B AS B.price < PREV(B.price) AND B.ts > PREV(B.ts)
)
----
2

statement error
SELECT count(*) FROM t_prev_only MATCH_RECOGNIZE (
    PARTITION BY p
    ORDER BY ts
    MEASURES A.id AS m
    AFTER MATCH SKIP TO NEXT ROW
    PATTERN ('A')
    DEFINE A AS PREV(PREV(A.price)) IS NULL
)
----
